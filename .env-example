# Telegram bot
TOKEN=0000000000:REPLACE_WITH_TELEGRAM_BOT_TOKEN
TG_CHANNEL_ID=-1000000000000
ADMIN_ID=123456789
ADMIN_NAME=admin
KMZ_PATH=geo_data/Покинутые_индустриальные_объекты.kmz
# Run initial places seeding from KMZ
SEED_PLACES=False

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=mydatabase
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Elasticsearch (used by AppSettings)
ELASTIC_URL=http://elasticsearch:9200
ELASTIC_USER=elastic
ELASTIC_PASSWORD=change_me

# Elasticsearch legacy compatibility (optional)
ELASTICSEARCH_HOST=http://elasticsearch:9200
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=change_me
